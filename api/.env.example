# Copy to `.env` and fill in. Set an Anthropic key OR configure Ollama.

# Provider: "auto" (default), "anthropic", or "ollama".
#   auto -> Anthropic when ANTHROPIC_API_KEY is set, otherwise Ollama.
LLM_PROVIDER=auto

# --- Anthropic (cloud) ---
# Your Anthropic API key (https://console.anthropic.com/). Required for Anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=16000

# --- Ollama (local) ---
# Used when the provider resolves to "ollama". Pull the model first:
#   ollama pull llama3.1
# In Docker, point OLLAMA_HOST at the host, e.g. http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_NUM_CTX=8192

# JSON array of allowed browser origins for CORS (optional).
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
